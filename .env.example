# Copy this file to .env.local for local daemon testing.

# Local runtime
LOCAL_RUNTIME_HOST=127.0.0.1
LOCAL_RUNTIME_PORT=8788
LOCAL_RUNTIME_STATE_DIR=.local-runtime/state
LOCAL_RUNTIME_POLL_INTERVAL_SECONDS=2
LOCAL_RUNTIME_PROCESS_OPEN_MODEL=true

# GitHub App
OZ_GITHUB_WEBHOOK_SECRET=replace-with-your-webhook-secret
OZ_GITHUB_APP_ID=replace-with-your-app-id
OZ_GITHUB_APP_PRIVATE_KEY_FILE=./github-app-private-key.pem
# Alternatively, set OZ_GITHUB_APP_PRIVATE_KEY with the PEM content.
GITHUB_API_BASE_URL=https://api.github.com

# Review backend
REVIEW_AGENT_BACKEND=open-model
OPEN_MODEL_RUN_STORE_DIR=.local-runtime/open-model-runs
OPEN_MODEL_API_BASE_URL=https://openrouter.ai/api/v1
OPEN_MODEL_API_KEY=replace-with-your-provider-key
OPEN_MODEL_MODEL=openai/gpt-4.1-mini
OPEN_MODEL_TEMPERATURE=0
OPEN_MODEL_TIMEOUT_SECONDS=120
